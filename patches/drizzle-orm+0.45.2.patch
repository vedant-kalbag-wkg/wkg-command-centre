@@ -55,13 +55,19 @@ class PgDialect {
 		`;
     await session.execute(import_sql2.sql`CREATE SCHEMA IF NOT EXISTS ${import_sql2.sql.identifier(migrationsSchema)}`);
     await session.execute(migrationTableCreate);
+    // Patched (wkg-kiosk-tool): check per-hash membership instead of
+    // comparing each migration's folderMillis against max(created_at).
+    // The upstream max-compare silently skips migrations whose folderMillis
+    // is older than the journal's max — happens after branch merges that
+    // renumber migrations. See scripts/apply-missing-migrations.ts for the
