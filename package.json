{
  "name": "wkg-kiosk-tool",
  "version": "0.1.0",
  "description": "Unified kiosk operations + analytics platform (WeKnow Group)",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx --env-file=.env.local --tsconfig tsconfig.json src/db/seed.ts",
    "db:seed:sales-demo": "npx tsx --env-file=.env.local --tsconfig tsconfig.json src/db/seed-sales-demo.ts",
    "db:seed:kiosks": "npx tsx --env-file=.env.local --tsconfig tsconfig.json src/db/seed-kiosks.ts",
    "db:seed:markets": "npx tsx --env-file=.env.local --tsconfig tsconfig.json src/db/seed-markets.ts",
    "db:import:monday": "npx tsx --env-file=.env.local --tsconfig tsconfig.json scripts/import-from-monday.ts",
    "db:enrich:locations": "npx tsx --env-file=.env.local --tsconfig tsconfig.json scripts/enrich-locations-from-monday.ts",
    "db:import:location-products": "npx tsx --env-file=.env.local --tsconfig tsconfig.json scripts/import-location-products-from-monday.ts",
    "etl:azure": "npx tsx --env-file=.env.local --tsconfig tsconfig.json scripts/run-azure-etl.ts",
    "test:e2e:remote": "playwright test --config=playwright.remote.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@base-ui/react": "^1.3.0",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/supabase-js": "^2.103.3",
    "@svar-ui/react-gantt": "^2.5.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-big-calendar": "^1.16.3",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "patch-package": "^8.0.0",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "testcontainers": "^11.14.0",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
